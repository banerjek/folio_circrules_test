{
  "manifest_version": 3,
  "name": "FOLIO Circulation Rules Checker",
  "version": "1.0",
  "description": "In-page modal to resolve FOLIO circulation rule lines using the active UI session.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "cookies"
  ],

  "optional_host_permissions": [
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "FOLIO Circulation Rules"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "modal.css"
      ],
      "matches": ["*://*/*"]
    }
  ]
}
